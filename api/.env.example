# Conexión a Postgres
DATABASE_URL="postgresql://cialo:cialo@localhost:5433/cialo_hub?schema=public"

# Servidor
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# JWT (cambiar en producción por valores aleatorios largos)
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# Email (SMTP) — opcional en dev
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Cialo Hub <no-reply@cialo.cl>"

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contacto@cialo.cl"

# Usuario admin inicial (seed)
SEED_ADMIN_EMAIL="admin@cialo.cl"
SEED_ADMIN_PASSWORD="admin1234"
