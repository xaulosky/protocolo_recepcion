// Cialo Hub — esquema de base de datos
// Convención: la data de la clínica conserva sus ids originales (slugs/números)
// para preservar las relaciones que ya existían en los archivos estáticos.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Auth & usuarios ─────────────────────────────

enum Role {
  ADMIN
  RECEPCION
  PROFESIONAL
  LECTURA
  // Estación de un box (ej. "Box 3"): solo ve mensajería. Su línea con Recepción
  // es un buzón privado (Conversation.buzonBoxId).
  BOX
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nombre       String
  role         Role     @default(RECEPCION)
  activo       Boolean  @default(true)
  // Secciones (ViewIds) que el usuario puede ver. Vacío = usar defaults del rol.
  permisos     String[] @default([])
  // Cuenta compartida/estación (ej. "Recepción"): se oculta del selector de
  // mensajes directos; se le escribe por el canal, no como DM individual.
  ocultarEnDM  Boolean  @default(false)
  // Si el usuario es un profesional, enlaza a su ficha clínica.
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  tareasAsignadas   Task[]             @relation("TareaAsignadas")
  tareasCreadas     Task[]             @relation("TareaCreador")
  taskActivities    TaskActivity[]
  cirugiasCreadas   Cirugia[]          @relation("CirugiaCreador")
  comunicacionLogs  ComunicacionLog[]
  cirugiaActividad  CirugiaActividad[] @relation("CirugiaActividadUsuario")
  signedConsents    SignedConsent[]    @relation("ConsentCreador")
  chatMemberships   ConversationMember[]
  mensajes          Message[]
  reacciones        MessageReaction[]
  quotes            Quote[]            @relation("QuoteCreador")
  giftCards         GiftCard[]         @relation("GiftCardCreador")
  reembolsos        SolicitudReembolso[] @relation("ReembolsoCreador")
  // Si el usuario es una estación Box, su buzón privado con Recepción.
  buzon             Conversation? @relation("BuzonBox")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// Refresh tokens con rotación: se guarda solo el hash del token.
model RefreshToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Token de recuperación de contraseña: se guarda solo el hash (sha256).
model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ───────────────────────────── Notificaciones ─────────────────────────────

enum NotificationType {
  TAREA_ASIGNADA
  TAREA_ACTUALIZADA
  REEMBOLSO
  SISTEMA
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType @default(SISTEMA)
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ───────────────────────────── Tareas (Kanban) ─────────────────────────────

enum Etapa {
  PENDIENTE
  ASIGNADO
  EN_PROCESO
  REVISION
  CERRADO
}

enum Prioridad {
  BAJA
  NORMAL
  URGENTE
}

// ─────────────────────────────── Cirugías / Procedimientos ─────────────────────────────────

enum EtapaCirugia {
  EVALUACION
  PRESUPUESTO_ENVIADO
  CONFIRMADO
  PREPARACION
  EN_EJECUCION
  POST_OPERATORIO
  CERRADO
}

enum PresupuestoEstado {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum InsumoTipo {
  INSUMO
  INSTRUMENTAL
}

enum CanalComunicacion {
  LLAMADA
  EMAIL
  WHATSAPP
  PRESENCIAL
  OTRO
}

model Task {
  id          String    @id @default(cuid())
  tipo        String
  descripcion String
  paciente    String?
  etapa       Etapa     @default(PENDIENTE)
  prioridad   Prioridad @default(NORMAL)
  dueAt       DateTime?
  tags        String[]  @default([])

  asignadas    User[]  @relation("TareaAsignadas")
  creadoPor    User?   @relation("TareaCreador", fields: [creadoPorId], references: [id])
  creadoPorId  String?

  activities TaskActivity[]
  checklist  TaskChecklist[]

  // Vinculación opcional con un procedimiento/cirugía
  cirugiaId   String?
  cirugia     Cirugia? @relation(fields: [cirugiaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([etapa])
  @@index([dueAt])
  @@index([cirugiaId])
}

model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tipo      String
  detalle   String?
  createdAt DateTime @default(now())

  @@index([taskId])
}

model TaskChecklist {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  contenido String
  done      Boolean  @default(false)
  orden     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([taskId])
}

// ───────────────────────────── Comercial ─────────────────────────────

enum GiftCardEstado {
  ACTIVA
  CANJEADA
  ANULADA
}

enum ReembolsoEstado {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
}

// Presupuesto generado en la sección Comercial (no vinculado a cirugía).
model Quote {
  id          String   @id @default(cuid())
  paciente    String
  rut         String?
  telefono    String?
  email       String?
  items       Json     @default("[]") // [{ nombre, cat, precio, cantidad }]
  subtotal    Int      @default(0)
  descuento   Int      @default(0) // porcentaje 0-100
  total       Int      @default(0)
  notas       String?
  creadoPor   User?    @relation("QuoteCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  creadoPorId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([creadoPorId])
  @@index([createdAt])
}

model GiftCard {
  id          String          @id @default(cuid())
  para        String
  de          String?
  monto       Int
  codigo      String          @unique
  mensaje     String?
  estado      GiftCardEstado  @default(ACTIVA)
  canjeoAt    DateTime?
  notas       String?
  creadoPor   User?           @relation("GiftCardCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  creadoPorId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([estado])
  @@index([createdAt])
}

model SolicitudReembolso {
  id          String          @id @default(cuid())
  paciente    String
  rut         String?
  telefono    String?
  fechaPago   String?         // texto libre para flexibilidad (ej. "12/06/2026")
  monto       String?         // texto libre (ej. "$150.000")
  motivo      String
  banco       String?
  cuenta      String?
  urgente     Boolean         @default(false)
  estado      ReembolsoEstado @default(PENDIENTE)
  notas       String?         // notas internas del equipo
  creadoPor   User?           @relation("ReembolsoCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  creadoPorId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([estado])
  @@index([urgente])
  @@index([createdAt])
}

// ───────────────────────────── Chat interno ─────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  esGrupo   Boolean  @default(false)
  // Canal por rol: si `roles` no está vacío, es un canal cuyos miembros son
  // todos los usuarios activos con esos roles (ej. "Recepción").
  roles     Role[]   @default([])
  nombre    String?  // nombre del grupo/canal (null en DMs)
  // Para DMs: clave canónica "menorId:mayorId" → unicidad garantizada por la BD.
  dmKey     String?  @unique
  // Buzón de estación: conversación privada entre un Box y todo el equipo de
  // Recepción. `buzonBoxId` = la cuenta Box dueña; miembros = ese Box + todos
  // los usuarios activos con rol RECEPCION. El título es dinámico según quién mira:
  // el box ve "Recepción"; recepción ve el nombre del box.
  buzonBoxId String?  @unique
  buzonBox   User?    @relation("BuzonBox", fields: [buzonBoxId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // se toca con cada mensaje, para ordenar

  members  ConversationMember[]
  messages Message[]

  @@index([updatedAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  lastReadAt     DateTime?    // última vez que el usuario abrió la conversación
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  autor          User         @relation(fields: [autorId], references: [id], onDelete: Cascade)
  autorId        String
  contenido      String
  editedAt       DateTime?
  parent         Message?     @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  parentId       String?
  replies        Message[]    @relation("MessageReplies")
  createdAt      DateTime     @default(now())

  reactions MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([parentId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ───────────────────────────── Data clínica ─────────────────────────────

model Treatment {
  id                String   @id // slug original (ej. 'toxina-tercio-superior')
  categoria         String
  subcategoria      String?
  nombre            String
  descripcion       String
  profesional       String?
  especialidad      String?
  valorDesde        Int?
  valorHasta        Int?
  duracion          String?
  sesiones          String?
  protocolo         String?
  requiereEvaluacion Boolean @default(false)
  indicaciones      String[]
  contraindicaciones String[]
  preTratamiento    String[]
  postTratamiento   String[]
  extra             Json?

  profesionales TreatmentProfessional[]

  @@index([categoria])
}

model Professional {
  id             String   @id // slug original (ej. 'nicolas-laucirica')
  nombreCompleto String
  especialidad   String
  rut            String?
  telefono       String?
  email          String?
  disponibilidad Json?
  prestaciones   Json?
  extra          Json?

  tratamientos TreatmentProfessional[]
  usuarios     User[]
  cirugias     Cirugia[]

  @@index([especialidad])
}

// Tabla relacional muchos-a-muchos tratamiento ↔ profesional.
model TreatmentProfessional {
  treatment      Treatment    @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  treatmentId    String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  @@id([treatmentId, professionalId])
  @@index([professionalId])
}

model Product {
  id          Int    @id // id numérico original
  brand       String
  name        String
  price       Int
  category    String?
  description String?

  insumos CirugiaInsumo[]

  @@index([brand])
}

model Consultation {
  id            String  @id // slug original
  categoria     String?
  emoji         String?
  nombre        String
  descripcion   String
  valor         String
  duracion      String?
  reembolsable  Boolean @default(false)
  profesionales Json?
}

model Box {
  id              Int      @id // id numérico original
  nombre          String
  alias           String?
  tipo            String?
  descripcion     String?
  usosPrincipales String[]
  equipamiento    Json?
}

model Consent {
  id                String   @id // slug original
  title             String
  treatment         String
  introduction      String
  beneficios        String[]
  efectosSecundarios String[]
  contraindicaciones String[]
  cuidados          String[]
  extra             Json?

  firmas SignedConsent[]
}

// ─────────────────── Consentimientos enviados a firma digital ───────────────────

enum ConsentEstado {
  PENDIENTE // enviado, esperando firma del paciente
  FIRMADO   // el paciente firmó
  ANULADO   // recepción lo anuló
}

// Una instancia de un consentimiento enviado a un paciente para firma electrónica
// simple (Ley 19.799 + 20.584). El enlace público usa `token` como secreto.
model SignedConsent {
  id          String        @id @default(cuid())
  token       String        @unique // secreto del enlace público (/firma/:token)

  // Plantilla de origen + snapshot inmutable de su contenido al momento de enviar.
  consent     Consent?      @relation(fields: [consentId], references: [id], onDelete: SetNull)
  consentId   String?
  titulo      String
  tratamiento String
  snapshot    Json          // { introduction, beneficios[], efectosSecundarios[], contraindicaciones[], cuidados[] }

  // Datos del paciente (los completa recepción al enviar).
  paciente      String
  rut           String
  profesional   String
  procedimiento String
  telefono      String?
  email         String?
  fecha         String   // fecha mostrada en el documento (DD/MM/AAAA)

  estado      ConsentEstado @default(PENDIENTE)

  // Resultado de la firma (se llena cuando el paciente firma).
  firmaImagen    String?   @db.Text // dataURL PNG de la firma dibujada
  firmanteNombre String?            // nombre que confirmó el paciente
  fotoAuth       Boolean?           // true = autoriza registro fotográfico, false = no, null = sin firmar
  firmadoAt      DateTime?
  firmaIp        String?            // evidencia de auditoría
  firmaUserAgent String?

  creadoPor   User?         @relation("ConsentCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  creadoPorId String?

  emailEnviadoAt DateTime?          // última vez que se envió el correo al paciente
  firmaManual    Boolean  @default(false) // firmado en papel (presencial), marcado por recepción
  expiresAt      DateTime?          // vencimiento del enlace (null = sin límite para registros legacy)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([createdAt])
}

model FaqItem {
  id        String   @id // slug original
  categoria String
  pregunta  String
  respuesta String
  tags      String[]

  @@index([categoria])
}

// Protocolos base de recepción (protocolRules).
model Protocol {
  id      String @id // número como string ('1'..'17')
  numero  Int
  titulo  String
  contenido String

  @@index([numero])
}

// Guiones técnicos (scriptsData), aplanados por categoría.
model Script {
  id        String  @id @default(cuid())
  categoria String
  titulo    String
  contenido String  @db.Text
  nota      String?
  orden     Int     @default(0)

  @@index([categoria])
}

// Políticas de pago y de paquetes (paymentPolicies).
model PaymentPolicy {
  id       String @id @default(cuid())
  titulo   String
  contenido String @db.Text
  tipo     String
  orden    Int    @default(0)

  @@index([tipo])
}

// Protocolos internos por área (protocolsData).
model InternalProtocol {
  id       String @id // clave original (ej. 'recepcion')
  titulo   String
  icon     String?
  color    String?
  sections Json
  orden    Int    @default(0)
}

// ─────────────────────────────── Cirugías / Procedimientos ─────────────────────────────────

model Cirugia {
  id             String        @id @default(cuid())
  paciente       String
  tipo           String        // texto libre: "Rinoplastia", "Blefaroplastia", etc.
  telefono       String?
  email          String?
  etapa            EtapaCirugia  @default(EVALUACION)
  etapaCambiadaAt  DateTime?
  notas            String?
  fechaCirugia     DateTime?

  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  professionalId String?

  creadoPor      User?         @relation("CirugiaCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  creadoPorId    String?

  presupuesto    Presupuesto?
  insumos        CirugiaInsumo[]
  comunicaciones ComunicacionLog[]
  actividad      CirugiaActividad[]
  tareas         Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([etapa])
  @@index([professionalId])
}

model Presupuesto {
  id          String            @id @default(cuid())
  cirugia     Cirugia           @relation(fields: [cirugiaId], references: [id], onDelete: Cascade)
  cirugiaId   String            @unique
  monto       Int               @default(0)
  descuento   Int               @default(0)
  estado      PresupuestoEstado @default(PENDIENTE)
  enviadoAt   DateTime?
  notas       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model CirugiaInsumo {
  id        String     @id @default(cuid())
  cirugia   Cirugia    @relation(fields: [cirugiaId], references: [id], onDelete: Cascade)
  cirugiaId String
  tipo      InsumoTipo @default(INSUMO)
  nombre    String
  product   Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId Int?
  cantidad  Int        @default(1)
  unidad    String?
  listo     Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([cirugiaId])
}

model ComunicacionLog {
  id          String            @id @default(cuid())
  cirugia     Cirugia           @relation(fields: [cirugiaId], references: [id], onDelete: Cascade)
  cirugiaId   String
  canal       CanalComunicacion @default(LLAMADA)
  descripcion String
  usuario     User              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId   String
  createdAt   DateTime          @default(now())

  @@index([cirugiaId])
}

model CirugiaActividad {
  id          String   @id @default(cuid())
  cirugia     Cirugia  @relation(fields: [cirugiaId], references: [id], onDelete: Cascade)
  cirugiaId   String
  tipo        String   // "ETAPA" | "PRESUPUESTO" | "INSUMO" | "TAREA"
  descripcion String
  datos       Json?
  usuario     User     @relation("CirugiaActividadUsuario", fields: [usuarioId], references: [id])
  usuarioId   String
  createdAt   DateTime @default(now())

  @@index([cirugiaId])
}
